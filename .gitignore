# ───────────────────────────── Secrets ──────────────────────────────
.env
.env.*
!.env.example

# ──────────────────────────── Python ────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
coverage.xml

# ──────────────────────────── Node / Next.js ────────────────────────
node_modules/
web/.next/
web/out/
web/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ──────────────────────── Runtime / generated data ──────────────────
# Per-run workspaces, uploaded codebases and artifacts are generated at
# runtime and must never be committed.
data/artifacts/*
data/workspaces/*
data/run_workspaces/*
!data/**/.gitkeep
artifacts/
workspace/

# ───────────────────────────── ML caches ────────────────────────────
ml/.cache/
ml/outputs/
ml/runs/
*.bin
*.safetensors
hf_cache/

# ──────────────────────────── Editor / OS ───────────────────────────
.idea/
.vscode/
*.swp
*~
.DS_Store
Thumbs.db
